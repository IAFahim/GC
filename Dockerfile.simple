# Simple Dockerfile for GC (Git Copy)
# This works on Windows, Mac, and Linux

FROM mcr.microsoft.com/dotnet/sdk:10.0

WORKDIR /app

# Install git (required for GC to work)
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

# Copy all source files
COPY . .

# Build the project (without AOT for Docker compatibility)
RUN dotnet build -c Release -p:PublishAot=false

# Default command - show help
CMD ["dotnet", "run", "--project", "GC/GC.csproj", "--", "--help"]
