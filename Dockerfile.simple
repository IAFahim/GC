# Simple Dockerfile for gc (Git Copy)
# Uses the full .NET SDK to run the project directly

FROM mcr.microsoft.com/dotnet/sdk:10.0

WORKDIR /app

# Install git (required for gc to work)
RUN apt-get update && \
    apt-get install -y git && \
    rm -rf /var/lib/apt/lists/*

# Copy the entire project
COPY . .

# Restore dependencies
RUN dotnet restore gc/gc.csproj

# Run gc --help by default
ENTRYPOINT ["dotnet", "run", "--project", "gc/gc.csproj", "--"]
CMD ["--help"]
